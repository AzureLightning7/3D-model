# ===== Web (apps/web/.env) =====
VITE_API_BASE_URL=http://localhost:8000/api/v1
VITE_DEFAULT_LOCALE=zh-CN
VITE_DEFAULT_THEME=dormvibe-default

# ===== API (apps/api/.env) =====
APP_ENV=local
APP_LOG_LEVEL=info
APP_BASE_URL=http://localhost:8000
# Comma-separated list of browser origins allowed by CORS.
APP_CORS_ORIGINS=http://localhost:5173,http://127.0.0.1:5173

# Local file-backed services (no Docker)
DATABASE_URL=sqlite:///./dormvibe.db
STORAGE_DIR=./storage
STORAGE_PUBLIC_BASE_URL=http://localhost:8000/storage

# Auth — JWT_SECRET MUST be overridden with 32+ random bytes outside local dev.
# The API refuses to start in staging/production with the insecure default.
JWT_SECRET=change-me-to-32-random-bytes
JWT_ACCESS_TTL_SECONDS=900
JWT_REFRESH_TTL_SECONDS=2592000

# AI providers (fill in when ready)
AI_DEFAULT_LLM_PROVIDER=qwen
AI_DEFAULT_IMAGE_PROVIDER=replicate
AI_DEFAULT_3D_PROVIDER=replicate
AI_DEFAULT_REGION=cn

REPLICATE_API_TOKEN=
QWEN_API_KEY=
QWEN_BASE_URL=https://dashscope.aliyuncs.com/compatible-mode/v1
DEEPSEEK_API_KEY=
ANTHROPIC_API_KEY=
OPENAI_API_KEY=
